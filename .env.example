# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API) - usado na geração de conteúdo (knowledge / chat)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Softcom IA Router (proxy compatível com Anthropic) — usado pelo Gestor de
# Prompt em /atendimentos/gestor-prompt. Se IAROUTER_API_KEY não estiver
# setada, cai em ANTHROPIC_API_KEY como fallback.
IAROUTER_BASE_URL=https://iarouter.softcomia.com/v1
IAROUTER_MODEL=claude-opus-4-6
IAROUTER_API_KEY=your-iarouter-api-key

# OpenAI (ChatGPT) - usado no chat de teste
OPENAI_API_KEY=your-openai-api-key

# API Authentication (for external consumers)
API_SECRET_KEY=your-api-secret-key
